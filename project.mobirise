        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "overflow": "hidden",
            ".media-container-row .mbr-text": {
              "color": "#232323"
            }
          },
          "_name": "footer04",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"footer4\" group=\"Footers\" global once=\"footers\" mbr-class=\"{'mbr-reveal': reveal, 'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"8\" step=\"1\" value=\"2\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"2\">\n        <input type=\"checkbox\" title=\"Reveal effect\" name=\"reveal\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n        </fieldset>\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#2e481a\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.6\" condition=\"overlay && bg.type !== 'color'\">\n        <!-- End block parameters -->\n    </mbr-parameters>\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div class=\"container\">\n        <div class=\"media-container-row align-center mbr-white\">\n            <div class=\"col-12\">\n                <p class=\"mbr-text mb-0 mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".media-container-row .mbr-text\" data-app-placeholder=\"Type Text\">\n                    2026 Apartment am Rohrbach<br><a href=\"impressum.html\" class=\"text-black text-primary\">Impressum&nbsp;Datenschutz AGBs</a><br></p>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "vhNafcgkaA",
          "_protectedParams": [],
          "_global": true,
          "_once": "footers",
          "_params": {},
          "_anchor": "footer04-1k"
        },
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".mbr-section-title": {
              "text-align": "center"
            },
            ".mbr-section-subtitle": {
              "text-align": "center"
            }
          },
          "_name": "list02",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"content4\" group=\"Content\" data-bg-video=\"{{bg.type == 'video'&&bg.value.url}}\" mbr-class=\"{'mbr-fullscreen': fullScreen, 'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"6\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"6\" condition=\"fullScreen == false\">\n        <input type=\"range\" name=\"textWidth\" title=\"Width\" min=\"4\" max=\"12\" step=\"1\" value=\"10\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\" checked>\n        <input type=\"checkbox\" title=\"Question\" name=\"showQuestion\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.7\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\">\n    </div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-lg-{{textWidth}}\">\n                <div class=\"title col-md-12 mb-5\">\n                    <h3 class=\"mbr-section-title mbr-fonts-style\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\">\n                        <b>Impressum</b></h3>\n                    <h4 class=\"mbr-section-subtitle mbr-fonts-style mb-0 mt-4\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-7\"></h4>\n                </div>\n                <div class=\"item features-without-image col-12\">\n                    <div class=\"item-wrapper\">\n                        <div class=\"card-box align-left\">\n                            <h5 class=\"card-title mbr-fonts-style mb-3\" mbr-theme-style=\"display-5\" mbr-if=\"showQuestion\" data-app-selector=\".card-title, .iconfont-wrapper\"></h5>\n                            <p class=\"card-text mbr-fonts-style mb-5\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\"><b>\n                                ​Impressum:​<br></b>Angaben gemäß § 5 TMG<br><br>Bucher UG (haftungsbeschränkt)<br>Werner-Diedrich-Straße 5<br>88045 Friedrichshafen<br>Deutschland<br><br>Kontakt:<br>E-Mail: info@apartment-am-rohrbach.de<br><br>Registereintrag:<br>Eintragung im Handelsregister<br>Registergericht: Amtsgericht Ulm<br>Registernummer: HRB 744229<br><br>Umsatzsteuer-ID:<br>Umsatzsteuer-Identifikationsnummer gemäß § 27a Umsatzsteuergesetz: DE353519773<br>Finanzamt Friedrichshafen<br><br>Verantwortlich für den Inhalt nach § 18 Abs. 2 MStV:<br>Bucher UG (haftungsbeschränkt)&nbsp;<br>Werner-Diedrich-Straße 5<br>88045 Friedrichshafen<br>Deutschland<br><br>EU-Streitschlichtung:<br>Die Europäische Kommission stellt eine Plattform zur Online-Streitbeilegung (OS) bereit:<br>https://ec.europa.eu/consumers/odr/<br><br>Unsere E-Mail-Adresse finden Sie oben im Impressum.<br><br>Verbraucherstreitbeilegung / Universalschlichtungsstelle:<br>Wir sind zur Teilnahme an einem Streitbeilegungsverfahren vor einer Verbraucherschlichtungsstelle weder verpflichtet noch bereit.<br><br>​Haftung für Inhalte:​<br>Als Diensteanbieter sind wir gemäß § 7 Abs.1 TMG für eigene Inhalte auf diesen Seiten nach den allgemeinen Gesetzen verantwortlich. <br>Nach §§ 8 bis 10 TMG sind wir als Diensteanbieter jedoch nicht verpflichtet, übermittelte oder gespeicherte fremde Informationen zu überwachen.<br><br>Haftung für Links:<br>Unsere Website enthält Links zu externen Websites Dritter, auf deren Inhalte wir keinen Einfluss haben. Deshalb können wir für diese fremden Inhalte auch keine Gewähr übernehmen.<br><br>Urheberrecht:<br>Die durch die Seitenbetreiber erstellten Inhalte und Werke auf diesen Seiten unterliegen dem deutschen Urheberrecht.<br><br><b><br></b><br><b>Datenschutzerklärung:<br></b><br>1. Datenschutz auf einen Blick<br>Die folgenden Hinweise geben einen Überblick darüber, was mit Ihren personenbezogenen Daten passiert, wenn Sie unsere Website besuchen.<br><br>2. Verantwortlicher<br>Bucher UG (haftungsbeschränkt)<br>Werner-Diedrich-Straße 5<br>88045 Friedrichshafen<br>Deutschland<br>E-Mail: info@apartment-am-rohrbach.de<br><br><br>3. Erhebung und Speicherung personenbezogener Daten<br><br>a) Beim Besuch der Website<br>Beim Aufrufen unserer Website werden automatisch Informationen durch den Hosting-Anbieter erfasst (Server-Logfiles):<br>Browsertyp und Browserversion<br>Betriebssystem<br>Referrer<br> URL<br>Hostname<br>Uhrzeit der Anfrage<br>IP-Adresse<br><br>Rechtsgrundlage: Art. 6 Abs. 1 lit. f DSGVO<br><br>b) Kontaktaufnahme<br>Bei Kontakt per E-Mail oder Formular werden Ihre Angaben zur Bearbeitung gespeichert.<br>Rechtsgrundlage:Art. 6 Abs. 1 lit. b DSGVOArt. 6 Abs. 1 lit. f DSGVO<br><br>c) Buchungsanfragen<br>Wir verarbeiten Daten wie Name, Kontaktdaten und Aufenthaltszeitraum zur Durchführung von Buchungen.<br>Rechtsgrundlage: Art. 6 Abs. 1 lit. b DSGVO<br><br>4. Hosting<br><br>Unsere Website wird technisch über zwei Anbieter bereitgestellt:<br><br>a) Domain-Hosting<br>Die Domain wird bereitgestellt durch die STRATO AG, Otto-Ostrowski-Straße 7, 10249 Berlin, Deutschland.<br><br>Dabei kann es zur Verarbeitung personenbezogener Daten (z. B. IP-Adressen im Rahmen von DNS-Anfragen) kommen.<br><br>b) Webhosting / Bereitstellung der Website<br>Die Inhalte unserer Website werden über GitHub Inc. bereitgestellt (GitHub Pages).<br><br>Beim Aufruf unserer Website werden durch GitHub automatisch Server-Logfiles erfasst. Dies umfasst insbesondere:<br><br>IP-Adresse<br>Browserinformationen<br>Datum und Uhrzeit des Zugriffs<br><br>Diese Daten sind technisch erforderlich, um die Website auszuliefern und die Stabilität sowie Sicherheit zu gewährleisten.<br><br>Es kann dabei zu einer Datenübertragung in die USA kommen.<br><br>Rechtsgrundlage<br>Die Nutzung beider Dienste erfolgt auf Grundlage von Art. 6 Abs. 1 lit. f DSGVO (berechtigtes Interesse an einer sicheren und effizienten Bereitstellung unserer Website).<br><br>Auftragsverarbeitung<br>Soweit erforderlich, wurden Verträge zur Auftragsverarbeitung abgeschlossen bzw. es werden die Standardvertragsklauseln der EU verwendet.<br><br>5. Google Maps<br>Diese Website nutzt Google Maps (Google Ireland Limited, Irland).Zur Nutzung ist die Verarbeitung Ihrer IP-Adresse erforderlich.Die Nutzung erfolgt nur mit Ihrer Einwilligung über ein Cookie-Banner.<br>Rechtsgrundlage: Art. 6 Abs. 1 lit. a DSGVO<br><br>6. Booking.com<br>Unsere Website enthält Links zu Booking.com (Booking.com B.V., Niederlande).Beim Anklicken werden Daten an den Anbieter übertragen.Für die Datenverarbeitung ist ausschließlich Booking.com verantwortlich.<br><br>7. Cookies<br><br>Unsere Website verwendet Cookies.Notwendige Cookies: Art. 6 Abs. 1 lit. f DSGVOOptionale Cookies: Art. 6 Abs. 1 lit. a DSGVOEin Cookie-Banner wird eingesetzt.<br><br>8. SSL-/TLS-Verschlüsselung<br>Diese Seite nutzt eine SSL- bzw. TLS-Verschlüsselung.<br><br>9. Ihre Rechte<br>Sie haben das Recht auf:<br>Auskunft<br>Berichtigung<br>Löschung<br>Einschränkung<br>Datenübertragbarkeit<br>Widerspruch<br><br>10. Beschwerderecht<br>Zuständige Aufsichtsbehörde:Der Landesbeauftragte für den Datenschutz und die Informationsfreiheit Baden-Württemberg<br><br>11. Speicherdauer<br>Daten werden nur so lange gespeichert, wie es erforderlich ist oder gesetzliche Fristen bestehen.<br><br>12. Änderungen<br>Wir behalten uns vor, diese Datenschutzerklärung anzupassen.\n                            </p>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"item features-without-image col-12\">\n                    <div class=\"item-wrapper\">\n                        <div class=\"card-box align-left\">\n                            <h5 class=\"card-title mbr-fonts-style mb-3\" mbr-theme-style=\"display-5\" mbr-if=\"showQuestion\" data-app-selector=\".card-title, .iconfont-wrapper\"></h5>\n                            <p class=\"card-text mbr-fonts-style mb-5\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\"></p>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"item features-without-image col-12\">\n                    <div class=\"item-wrapper\">\n                        <div class=\"card-box align-left\">\n                            <h5 class=\"card-title mbr-fonts-style mb-3\" mbr-theme-style=\"display-5\" mbr-if=\"showQuestion\" data-app-selector=\".card-title, .iconfont-wrapper\"></h5>\n                            <p class=\"card-text mbr-fonts-style mb-5\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\"></p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
